{
  "name": "surf-events-server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "crates/surf-events-server",
  "sourceRoot": "crates/surf-events-server/src",
  "targets": {
    "build": {
      "executor": "@monodon/rust:build",
      "inputs": ["rust", "^rust"],
      "dependsOn": ["^build"],
      "outputs": ["{options.target-dir}"]
    },
    "test": {
      "executor": "@monodon/rust:test",
      "dependsOn": ["^build"],
      "inputs": ["rust", "^rust"],
      "outputs": ["{options.target-dir}"]
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "cargo run --manifest-path crates/surf-events-server/Cargo.toml",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
