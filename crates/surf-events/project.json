{
  "name": "surf-events",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "crates/surf-events",
  "sourceRoot": "crates/surf-events/src",
  "targets": {
    "build": {
      "executor": "@monodon/rust:build",
      "inputs": ["rust", "^rust"],
      "outputs": ["{options.target-dir}"],
      "options": {
        "lib": true
      }
    },
    "test": {
      "executor": "@monodon/rust:test",
      "dependsOn": ["^build"],
      "inputs": ["rust", "^rust"],
      "outputs": ["{options.target-dir}"]
    }
  }
}
